<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!--
        Reads loki.url from the Spring Environment (application.yml / env var
        override), same dual-mode pattern already used for BROKER_URL,
        DISCOVERY_SERVER_URL, etc.: works in the IDE (localhost) and in
        Docker/k8s (container/service name) without touching this file.
    -->
    <property name="lokiUrl" value="${LOKI_URL:-http://localhost:3100}"/>
    <property name="appName" value="auth-service"/>

    <!-- Console appender, plain text — for local dev readability -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Loki appender, JSON structured — for aggregation/search in Grafana -->
    <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
        <http>
            <url>${lokiUrl}/loki/api/v1/push</url>
        </http>
        <format>
            <label>
                <pattern>app=${appName},level=%level,host=${HOSTNAME}</pattern>
            </label>
            <message class="com.github.loki4j.logback.JsonLayout">
                <format>
                    <timestampFormat>yyyy-MM-dd'T'HH:mm:ss.SSSXXX</timestampFormat>
                </format>
            </message>
        </format>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="LOKI"/>
    </root>

</configuration>